@model IEnumerable<Sistema_Cinema.Models.Compra>

@{
    ViewData["Title"] = "Compras";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Compras</h1>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Id</th>
                <th>Cliente</th>
                <th>Data</th>
                <th>Qtd Itens</th>
                <th>Valor Itens</th>
                <th>Valor Ingressos</th>
                <th>Desconto</th>
                <th>Valor Final</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Id</td>
                <td>
                    @{ var nome = c.Cliente?.AppUser?.Nome ?? c.Cliente?.AppUser?.UserName ?? "—"; }
                    @nome
                </td>
                <td>@c.DataCompra.ToString("g")</td>
                <td>@(c.ItemCompras?.Sum(i => i.Quantidade) ?? 0)</td>
                <td>@((c.ItemCompras?.Sum(i => i.Subtotal) ?? 0m).ToString("C"))</td>
                <td>@c.ValorIngressos.ToString("C")</td>
                <td>@c.ValorDesconto.ToString("C")</td>
                <td>@c.ValorFinal.ToString("C")</td>
            </tr>
        }
        </tbody>
    </table>
</div>
