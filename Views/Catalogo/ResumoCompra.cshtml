@model Sistema_Cinema.Models.ResumoCompraViewModel

@{
    ViewData["Title"] = "Resumo da Compra";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/catalogo.css" />

<div class="container py-4">
    <h2 class="mb-4">Resumo da Compra</h2>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">@Model.Sessao.Filme?.Titulo</h5>
            <p class="card-text text-muted mb-0">
                <strong>Data:</strong> @Model.Sessao.DataHora.ToString("dd/MM/yyyy HH:mm") •
                <strong>Sala:</strong> @Model.Sessao.Sala?.NumeroSala •
                <strong>Preço:</strong> @Model.Sessao.PrecoBase.ToString("C")
            </p>
        </div>
    </div>

    <form asp-action="ConfirmarReserva" asp-controller="Catalogo" method="post" id="confirmForm">
        <input type="hidden" name="sessaoId" value="@Model.Sessao.Id" />

        <div class="mb-4">
            <h5 class="mb-3">Assentos Selecionados</h5>
            <div class="d-flex flex-wrap gap-2 mb-3">
                @for (int i = 0; i < Model.Assentos.Count; i++)
                {
                    <span class="badge bg-primary">
                        @Model.Assentos[i].Codigo
                        <input type="hidden" name="assentoIds" value="@Model.Assentos[i].Id" />
                    </span>
                }
            </div>
            <div class="alert alert-info mb-0">
                <strong>Subtotal Ingressos:</strong> <span id="subtotalIngressos">@Model.SubtotalIngressos.ToString("C")</span>
            </div>
        </div>

        <div class="mb-4">
            <h5 class="mb-3">Produtos</h5>
            @if (Model.Produtos.Count == 0)
            {
                <div class="alert alert-info mb-0">
                    Nenhum produto disponível para esta sessão.
                </div>
            }
            else
            {
                <p class="text-muted mb-3">Escolha produtos e defina a quantidade (0 significa não adicionar).</p>
                <div class="row g-3">
                    @for (int i = 0; i < Model.Produtos.Count; i++)
                    {
                        var produto = Model.Produtos[i];
                        <div class="col-12 col-md-6">
                            <div class="card h-100" data-preco="@produto.Preco">
                                @if (!string.IsNullOrEmpty(produto.UrlImagem))
                                {
                                    <img src="@produto.UrlImagem" class="card-img-top" alt="@produto.Nome" style="height: 200px; object-fit: cover;">
                                }
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title">@produto.Nome</h6>
                                    <p class="card-text text-muted small mb-3">@produto.Descricao</p>
                                    
                                    <div class="d-flex justify-content-between align-items-end gap-2 mt-auto">
                                        <div>
                                            <strong class="d-block">@produto.Preco.ToString("C")</strong>
                                            <small class="text-muted">Unit.</small>
                                        </div>
                                        <div class="flex-grow-1">
                                            <input type="hidden" name="produtos[@i].Id" value="@produto.Id" />
                                            <input type="number" name="produtos[@i].Quantidade" value="0" min="0" max="@produto.QuantidadeDisponivel" class="form-control form-control-sm produto-quantidade" data-preco="@produto.Preco" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="mb-4">
            <h5 class="mb-3">Cupom de Desconto</h5>
            <div class="input-group">
                <input type="text" name="cupomCodigo" class="form-control" placeholder="Código do cupom (opcional)" />
            </div>
        </div>

        <div class="card mb-4 bg-light">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span>Subtotal Produtos:</span>
                    <span id="subtotalProdutos">R$ 0,00</span>
                </div>
                <div class="d-flex justify-content-between fw-bold">
                    <span>Total:</span>
                    <span id="totalSemDesconto">@Model.SubtotalIngressos.ToString("C")</span>
                </div>
            </div>
        </div>

        <button type="submit" id="btnConfirmar" class="btn btn-success btn-lg w-100">
            Confirmar Compra
        </button>
    </form>
</div>

<script src="~/js/catalogo.js"></script>
