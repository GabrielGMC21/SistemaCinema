@model Sistema_Cinema.Models.FilmeDetalhesViewModel

@{
    ViewData["Title"] = Model.Filme.Titulo;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/catalogo.css" />

<div class="mb-4">
    <a asp-controller="Catalogo" asp-action="Index" class="btn btn-outline-secondary btn-sm">← Voltar</a>
</div>

<div class="container-fluid">
    <div class="row g-4 mb-5">
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <img src="@Model.Filme.UrlPoster" class="card-img-top" alt="@Model.Filme.Titulo" style="object-fit: contain; height: 480px; background-color: #f8f9fa;">
            </div>
        </div>

        <div class="col-lg-9">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h1 class="mb-1">@Model.Filme.Titulo</h1>
                    <p class="text-muted mb-4 fw-semibold">Dirigido por @Model.Filme.Diretor</p>

                    <div class="row g-3 mb-4">
                        <div class="col-6 col-md-3">
                            <small class="d-block text-muted text-uppercase fw-semibold mb-1">Gênero</small>
                            <p class="mb-0">@Model.Filme.Genero</p>
                        </div>
                        <div class="col-6 col-md-3">
                            <small class="d-block text-muted text-uppercase fw-semibold mb-1">Ano</small>
                            <p class="mb-0">@Model.Filme.Ano</p>
                        </div>
                        <div class="col-6 col-md-3">
                            <small class="d-block text-muted text-uppercase fw-semibold mb-1">Duração</small>
                            <p class="mb-0">@Model.Filme.GetDuracaoFormatada()</p>
                        </div>
                        <div class="col-6 col-md-3">
                            <small class="d-block text-muted text-uppercase fw-semibold mb-1">Classificação</small>
                            @{
                                var classificacaoFile = $"{(int)Model.Filme.Classificacao}_Borda.png";
                            }
                            <img src="@Url.Content($"~/images/classificacoes/{classificacaoFile}")" style="max-width: 50px;" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="mb-2 fw-semibold">Sinopse</h6>
                        <p class="text-secondary lh-base">@Model.Filme.Sinopse</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <h5 class="card-title mb-0">Sessões Disponíveis</h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.Filme.Sessoes != null && Model.Filme.Sessoes.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Data e Hora</th>
                                        <th>Sala</th>
                                        <th>Capacidade</th>
                                        <th class="text-end pe-4">Preço</th>
                                        <th class="text-center pe-4" style="width: 100px;">Ação</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sessao in Model.Filme.Sessoes)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <strong>@sessao.DataHora.ToString("dd/MM/yyyy HH:mm")</strong>
                                            </td>
                                            <td>
                                                <span class="badge bg-info text-dark">Sala @sessao.Sala?.NumeroSala</span>
                                            </td>
                                            <td>
                                                @sessao.Sala?.Capacidade
                                            </td>
                                            <td class="text-end pe-4">
                                                <strong>@sessao.PrecoBase.ToString("C")</strong>
                                            </td>
                                            <td class="text-center pe-4">
                                                <a asp-controller="Catalogo" asp-action="AssentosDisponiveis" asp-route-id="@sessao.Id" class="btn btn-primary btn-sm">Comprar</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0 m-3" role="alert">
                            <i class="bi bi-exclamation-triangle"></i> Nenhuma sessão disponível para este filme no momento.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">Avaliações</h5>
                        @if (Model.TotalAvaliacoes > 0)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-warning text-dark fs-6">⭐ @Model.MediaAvaliacao.ToString("F1")</span>
                                <small class="text-muted">(@Model.TotalAvaliacoes @(Model.TotalAvaliacoes == 1 ? "avaliação" : "avaliações"))</small>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["ErroAvaliacao"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["ErroAvaliacao"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["SucessoAvaliacao"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SucessoAvaliacao"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @{ 
                        var avaliacoes = Model.Avaliacoes;
                        var minhaAvaliacao = Model.MinhaAvaliacao;
                        var podeAvaliar = Model.PodeAvaliar;
                    }

                    @if (minhaAvaliacao != null)
                    {
                        <div class="alert alert-light border border-secondary mb-4 p-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="mb-1 fw-semibold">✓ Sua Avaliação</h6>
                                    <small class="text-muted">@minhaAvaliacao.DataAvaliacao.ToString("dd/MM/yyyy")</small>
                                </div>
                                <div>
                                    <button type="button" class="btn btn-sm btn-warning" onclick="mostrarFormularioEdicao()">Editar</button>
                                    <form asp-action="DeletarAvaliacao" asp-controller="Catalogo" method="post" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="avaliacaoId" value="@minhaAvaliacao.Id" />
                                        <input type="hidden" name="filmeId" value="@Model.Filme.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Tem certeza que deseja deletar esta avaliação?');">
                                            Deletar
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <div class="mt-2">
                                <span class="badge bg-warning text-dark mb-2">@minhaAvaliacao.Nota / 5</span>
                                @if (!string.IsNullOrEmpty(minhaAvaliacao.Comentario))
                                {
                                    <p class="mb-0 mt-2 text-secondary">@minhaAvaliacao.Comentario</p>
                                }
                            </div>
                        </div>
                    }

                    @if (User.Identity.IsAuthenticated)
                    {
                        @if (podeAvaliar)
                        {
                            <div id="formularioAvaliacao" class="@(minhaAvaliacao != null ? "d-none" : "") card bg-light mb-4 border-primary">
                                <div class="card-body">
                                    <h6 class="card-title mb-3">@(minhaAvaliacao != null ? "Editar sua avaliação" : "Escreva sua avaliação")</h6>
                                    <form id="formAvaliacao" method="post" class="row g-3">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="filmeId" value="@Model.Filme.Id" />
                                        @if (minhaAvaliacao != null)
                                        {
                                            <input type="hidden" name="avaliacaoId" value="@minhaAvaliacao.Id" />
                                        }
                                        
                                        <div class="col-md-3">
                                            <label class="form-label">Nota</label>
                                            <select name="nota" id="selectNota" class="form-select">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    if (minhaAvaliacao != null && minhaAvaliacao.Nota == i)
                                                    {
                                                        <option value="@i" selected>@i ⭐</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@i">@i ⭐</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Comentário (opcional)</label>
                                            <textarea name="comentario" id="textComentario" class="form-control" rows="3" placeholder="Compartilhe sua opinião sobre o filme...">@((minhaAvaliacao != null) ? minhaAvaliacao.Comentario : "")</textarea>
                                        </div>
                                        <div class="col-12 text-end">
                                            @if (minhaAvaliacao != null)
                                            {
                                                <button type="button" class="btn btn-secondary btn-sm" onclick="ocultarFormularioEdicao()">Cancelar</button>
                                                <button type="submit" formaction="@Url.Action("EditarAvaliacao", "Catalogo")" class="btn btn-primary btn-sm">Salvar Alterações</button>
                                            }
                                            else
                                            {
                                                <button type="submit" formaction="@Url.Action("CriarAvaliacao", "Catalogo")" class="btn btn-primary btn-sm">Enviar Avaliação</button>
                                            }
                                        </div>
                                    </form>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-4" role="alert">
                                <i class="bi bi-info-circle"></i> Somente é possível avaliar filmes que você assistiu.
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info mb-4" role="alert">
                            <a asp-area="Identity" asp-page="/Account/Login">Faça login</a> para avaliar este filme.
                        </div>
                    }

                    @if (avaliacoes != null && avaliacoes.Any())
                    {
                        @if (minhaAvaliacao != null || avaliacoes.Count > 0)
                        {
                            <hr class="my-4" />
                            <h6 class="mb-3">Outras Avaliações (@(avaliacoes.Count(a => minhaAvaliacao == null || a.Id != minhaAvaliacao.Id)))</h6>
                        }

                        @foreach (var a in avaliacoes)
                        {
                            @if (minhaAvaliacao != null && a.Id == minhaAvaliacao.Id)
                            {
                                continue;
                            }
                            
                            <div class="mb-3 pb-3 border-bottom">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <strong class="d-block">@(a.Cliente?.AppUser?.Nome ?? "Usuário Anônimo")</strong>
                                        <small class="text-muted">@a.DataAvaliacao.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <span class="badge bg-warning text-dark">@a.Nota/5</span>
                                </div>
                                @if (!string.IsNullOrEmpty(a.Comentario))
                                {
                                    <p class="mb-0 text-secondary">@a.Comentario</p>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        @if (minhaAvaliacao == null)
                        {
                            <div class="text-muted text-center py-4">
                                <i class="bi bi-chat-dots" style="font-size: 2rem; opacity: 0.5;"></i>
                                <p class="mt-2">Ainda não há avaliações para este filme.</p>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function mostrarFormularioEdicao() {
    const formulario = document.getElementById('formularioAvaliacao');
    formulario.classList.remove('d-none');
    formulario.scrollIntoView({ behavior: 'smooth' });
}

function ocultarFormularioEdicao() {
    const formulario = document.getElementById('formularioAvaliacao');
    formulario.classList.add('d-none');
}
</script>
