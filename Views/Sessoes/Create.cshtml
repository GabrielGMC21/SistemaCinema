@model Sistema_Cinema.Models.Sessao

@{
    ViewData["Title"] = "Cadastrar Sessão";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/sessoes.css" />

<h1 class="titulo">Cadastrar Sessão</h1>
<hr />
<div>
    <div>
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="DataHora" class="form-label"></label>
                    <input asp-for="DataHora" class="form-control" type="datetime-local" />
                    <span asp-validation-for="DataHora" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="PrecoBase" class="form-label"></label>
                    <input asp-for="PrecoBase" class="form-control" type="number" step="0.01" min="0" placeholder="0,00" />
                    <span asp-validation-for="PrecoBase" class="text-danger"></span>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="IdFilme" class="form-label">Filme</label>
                    <select asp-for="IdFilme" class="form-control" asp-items="ViewBag.IdFilme">
                        <option value="" hidden>-- Selecione um filme --</option>
                    </select>
                    <span asp-validation-for="IdFilme" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="IdSala" class="form-label">Sala</label>
                    <select asp-for="IdSala" class="form-control" asp-items="ViewBag.IdSala">
                        <option value="" hidden>-- Selecione uma sala --</option>
                    </select>
                    <span asp-validation-for="IdSala" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Cadastrar
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

