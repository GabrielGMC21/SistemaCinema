@model Sistema_Cinema.Models.Cliente

@{
    ViewData["Title"] = $"Usuário {@User.Identity?.Name}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var reservasValidas = Model.HistoricoCompras
        .SelectMany(c => c.Reservas)
        .Where(r => r.Sessao.DataHora + TimeSpan.FromMinutes(r.Sessao.Filme.Duracao) >= DateTime.Now)
        .OrderBy(r => r.Sessao.DataHora)
        .ToList();
}

<link rel="stylesheet" href="~/css/profile.css" />

<div class="container mt-4">
    <div class="row mb-5">
        <div class="col-md-12">
            <h2 class="mb-1">Bem-vindo, @User.Identity.Name</h2>
            <p class="text-muted">Gerencial seus ingressos, histórico de compras e avaliações</p>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-md-12">
            <div class="d-flex align-items-center mb-3">
                <h3 class="mb-0">🎬 Ingressos Disponíveis</h3>
                <span class="badge bg-primary ms-2">@reservasValidas.Count()</span>
            </div>
            
            @if (!reservasValidas.Any())
            {
                <div class="alert alert-info" role="alert">
                    <strong>Nenhum ingresso disponível</strong> - Você não possui ingressos para sessões futuras.
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var reserva in reservasValidas)
                    {
                        var dataHora = reserva.Sessao?.DataHora ?? DateTime.Now;
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card h-100 border-success shadow-sm">
                                <div class="card-header bg-success text-white">
                                    <h5 class="card-title mb-0">@reserva.Sessao?.Filme?.Titulo</h5>
                                </div>
                                <div class="card-body">
                                    <p class="card-text mb-2">
                                        <strong>Data/Hora:</strong><br>
                                        @dataHora.ToString("dd/MM/yyyy HH:mm")
                                    </p>
                                    <p class="card-text mb-2">
                                        <strong>Sala:</strong> @reserva.Sessao?.Sala?.NumeroSala
                                    </p>
                                    <p class="card-text mb-0">
                                        <strong>Assento:</strong> @reserva.Assento?.Codigo
                                    </p>
                                </div>
                                <div class="card-footer bg-light">
                                    <small class="text-muted">Compra realizada em @reserva.Compra?.DataCompra.ToString("dd/MM/yyyy")</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-md-12">
            <div class="d-flex align-items-center mb-3">
                <h3 class="mb-0">🛒 Histórico de Compras</h3>
                <span class="badge bg-secondary ms-2">@Model.HistoricoCompras.Count()</span>
            </div>
            
            @if (!Model.HistoricoCompras.Any())
            {
                <div class="alert alert-info" role="alert">
                    <strong>Sem compras</strong> - Você ainda não realizou nenhuma compra.
                </div>
            }
            else
            {
                @foreach (var compra in Model.HistoricoCompras.OrderByDescending(c => c.DataCompra))
                {
                    <div class="card mb-3 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="card-title mb-0">Compra #@compra.Id</h5>
                                <small class="text-muted">@compra.DataCompra.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            <div class="text-end">
                                <h5 class="mb-0 text-success">@compra.ValorFinal.ToString("C")</h5>
                                <small class="text-muted">@(compra.Reservas.Count() + compra.ItemCompras.Count()) item(ns)</small>
                            </div>
                        </div>
                        <div class="card-body">
                            @if (compra.Reservas.Any())
                            {
                                <h6 class="mb-2">Ingressos:</h6>
                                <ul class="mb-3 ps-3">
                                    @foreach (var reserva in compra.Reservas)
                                    {
                                        <li>
                                            <strong>@reserva.Sessao?.Filme?.Titulo</strong> 
                                            - Assento @reserva.Assento?.Codigo 
                                            (@reserva.Sessao?.DataHora.ToString("dd/MM/yyyy HH:mm"))
                                        </li>
                                    }
                                </ul>
                            }

                            @if (compra.ItemCompras.Any())
                            {
                                <h6 class="mb-2">Produtos:</h6>
                                <div class="table-responsive ps-3">
                                    <table class="table table-sm table-borderless mb-0">
                                        <tbody>
                                            @foreach (var item in compra.ItemCompras)
                                            {
                                                <tr>
                                                    <td>
                                                        <strong>@item.Produto?.Nome</strong>
                                                    </td>
                                                    <td class="text-end">
                                                        <span class="badge bg-info">@item.Quantidade x</span>
                                                    </td>
                                                    <td class="text-end text-success fw-bold">
                                                        @item.Subtotal.ToString("C")
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            @if (!compra.Reservas.Any() && !compra.ItemCompras.Any())
                            {
                                <p class="text-muted mb-0">Nenhum item nesta compra</p>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="d-flex align-items-center mb-3">
                <h3 class="mb-0">⭐ Avaliações</h3>
                <span class="badge bg-warning ms-2">@Model.Avaliacoes.Count()</span>
            </div>
            
            @if (!Model.Avaliacoes.Any())
            {
                <div class="alert alert-info" role="alert">
                    <strong>Nenhuma avaliação</strong> - Você ainda não fez nenhuma avaliação de filmes.
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var avaliacao in Model.Avaliacoes.OrderByDescending(a => a.DataAvaliacao))
                    {
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card h-100 shadow-sm">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">@avaliacao.Filme?.Titulo</h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <strong>Classificação:</strong><br>
                                        <span class="badge bg-warning text-dark fs-5">
                                            @{
                                                var stars = "";
                                                for (int i = 0; i < (int)avaliacao.Nota; i++)
                                                {
                                                    stars += "⭐ ";
                                                }
                                            }
                                            @stars @avaliacao.Nota.ToString("0.0") / 5
                                        </span>
                                    </div>
                                    <p class="card-text">
                                        <strong>Comentário:</strong><br>
                                        @if (string.IsNullOrEmpty(avaliacao.Comentario))
                                        {
                                            <em class="text-muted">Sem comentário</em>
                                        }
                                        else
                                        {
                                            @avaliacao.Comentario
                                        }
                                    </p>
                                </div>
                                <div class="card-footer bg-light">
                                    <small class="text-muted">@avaliacao.DataAvaliacao.ToString("dd/MM/yyyy")</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

