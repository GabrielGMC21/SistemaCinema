@model IEnumerable<Sistema_Cinema.Models.Produto>

@{
    ViewData["Title"] = "Produtos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/produtos.css" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Produtos</h1>
    <a asp-controller="Produtos" asp-action="Create" class="btn btn-primary">Cadastrar Produto</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th style="width:70px">Imagem</th>
                <th>Nome</th>
                <th>Categoria</th>
                <th>Descrição</th>
                <th>Quantidade</th>
                <th>Preço</th>
                <th class="text-end">Ações</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <img src="@item.UrlImagem" alt="@item.Nome" class="rounded" style="height: 50px; width: 50px; object-fit: cover;" />
                </td>

                <td>
                    <span>@item.Nome</span>
                </td>

                <td>
                    <div>@item.Categoria</div>
                </td>

                <td style="max-width:320px">
                    @{
                        if (!string.IsNullOrEmpty(item.Descricao) && item.Descricao.Length > 100)
                        {
                            @item.Descricao.Substring(0, 100)<text>...</text>
                        }
                        else
                        {
                            @item.Descricao
                        }
                    }
                </td>

                <td>
                    <span class="badge bg-info text-dark">@item.QuantidadeDisponivel</span>
                </td>

                <td>
                    <strong>@item.Preco.ToString("C")</strong>
                </td>

                <td class="text-end">
                    <a asp-controller="Produtos" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1">Editar</a>
                    <a asp-controller="Produtos" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">Detalhes</a>
                    <form asp-controller="Produtos" asp-action="Delete" method="post" class="d-inline delete-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                Excluir
                            </button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
