@model Sistema_Cinema.Models.Produto

@{
    ViewData["Title"] = Model.Nome;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/css/produtos.css" />
<div class="mb-4">
    <a asp-controller="Produtos" asp-action="Index" class="btn btn-outline-secondary">← Voltar para Produtos</a>
</div>

<div class="container-fluid">
    <div class="row">
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <img src="@Model.UrlImagem" class="card-img-top" alt="@Model.Nome" style="object-fit: contain; height: 400px;">
                <div class="card-body text-center">
                    <span class="badge bg-info mb-2" style="font-size: 17px">Quantidade: @Model.QuantidadeDisponivel</span>
                </div>
            </div>
        </div>

        <div class="col-lg-8 col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h1 class="card-title mb-1">@Model.Nome</h1>

                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="info-box">
                                <small class="d-block text-muted">Categoria</small>
                                <strong>@Model.Categoria</strong>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-box">
                                <small class="d-block text-muted">Preço</small>
                                <strong>@Model.Preco.ToString("C")</strong>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-box">
                                <small class="d-block text-muted">Disponível</small>
                                <strong>@(Model.QuantidadeDisponivel > 0 ? "Sim" : "Não")</strong>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="mb-4">
                        <h5>Descrição</h5>
                        <p class="text-justify">@Model.Descricao</p>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <a asp-controller="Produtos" asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">
                            <i class="bi bi-pencil"></i> Editar
                        </a>
                        <form asp-controller="Produtos" asp-action="Delete" method="post" class="d-inline delete-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model?.Id" />
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Excluir
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
