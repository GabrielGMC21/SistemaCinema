@model Sistema_Cinema.Models.Sala

@{
    ViewData["Title"] = "Cadastrar Sala";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/salas.css" />

<h1 class="titulo">Cadastrar Sala</h1>
<hr />
<div>
    <div>
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="NumeroSala" class="form-label"></label>
                    <input asp-for="NumeroSala" class="form-control" type="number" placeholder="Digite o número da sala" min="1" />
                    <span asp-validation-for="NumeroSala" class="text-danger"></span>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label for="linhas" class="form-label">Número de Linhas</label>
                    <input type="number" id="linhas" name="linhas" class="form-control" placeholder="Ex: 10" min="1" max="26" value="1" />
                </div>

                <div class="col-md-6">
                    <label for="assentosPorLinha" class="form-label">Assentos por Linha</label>
                    <input type="number" id="assentosPorLinha" name="assentosPorLinha" class="form-control" placeholder="Ex: 20" min="1" max="100" value="1" />
                </div>
            </div>

            <div class="mb-4">
                <button type="button" id="gerarPreview" class="btn btn-info">
                    Gerar Preview dos Assentos
                </button>
            </div>

            <div id="previewContainer" style="display: none;">
                <div class="mb-4 p-3 bg-light rounded">
                    <h5 class="mb-3">Preview dos Assentos</h5>
                    <div id="assentosPreview" style= "overflow-y: auto;"></div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Cadastrar
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/createSala.js"></script>
}
