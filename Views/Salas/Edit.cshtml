@model Sistema_Cinema.Models.Sala

@{
    ViewData["Title"] = "Editar Sala";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="titulo">Editar Sala</h1>
<hr />
<div>
    <div>
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input type="hidden" asp-for="Id" />

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="NumeroSala" class="form-label"></label>
                    <input asp-for="NumeroSala" class="form-control" type="number" min="1" />
                    <span asp-validation-for="NumeroSala" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Salvar
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

